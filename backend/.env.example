# --- Django core ---
# В проде ОБЯЗАТЕЛЬНО сгенерировать: `python -c "import secrets; print(secrets.token_urlsafe(64))"`
DJANGO_SECRET_KEY=change-me-in-production-please
DJANGO_DEBUG=1
# В проде укажите явный список хостов через запятую, '*' запрещён.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# В проде включите HTTPS-редирект и доверенные origin'ы для CSRF
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SECURE_HSTS_SECONDS=31536000
# CSRF_TRUSTED_ORIGINS=https://crm.aqualine.tj,https://cabinet.aqualine.tj

# --- DB ---
DATABASE_URL=postgres://aqualine:CHANGE_ME@db:5432/aqualine

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://:CHANGE_ME@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis:6379/1
CELERY_TASK_ALWAYS_EAGER=1

# --- Media ---
MEDIA_URL=/media/

# --- Web Push (VAPID) — `python manage.py generate_vapid_keys` ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@aqualine.tj
