DJANGO_SECRET_KEY=change-me-in-production-please
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
DATABASE_URL=postgres://aqualine:aqualine@db:5432/aqualine
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Celery / Redis (для задач: уведомления, PDF, отчёты)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=1

# Media uploads
MEDIA_URL=/media/

# Web Push (VAPID) — сгенерируйте через `python manage.py generate_vapid_keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@aqualine.tj
