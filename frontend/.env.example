# ---------- Frontend (Next.js) ----------
# Скопируйте этот файл в .env.local внутри apps/crm и apps/cabinet
# и подставьте реальные значения для своего окружения.

# Базовый URL backend API (Django REST)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# (опционально) Web Push VAPID public key — должен совпадать с backend VAPID_PUBLIC_KEY
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
