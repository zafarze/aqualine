{
  "name": "aqualine-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n crm,cabinet -c blue,magenta \"npm run dev -w crm\" \"npm run dev -w cabinet\"",
    "dev:crm": "npm run dev -w crm",
    "dev:cabinet": "npm run dev -w cabinet",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}
